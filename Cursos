<!DOCTYPE html>
<html>

<head>
<title>Matrícula - ULIMA</title>

<style>

body{
font-family:Arial;
background:#f5f5f5;
margin:0;
}

header{
background:#f36f21;
color:white;
padding:20px;
text-align:center;
}

.container{
width:70%;
margin:auto;
margin-top:40px;
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

h2{
color:#f36f21;
}

table{
width:100%;
border-collapse:collapse;
}

th{
background:#f36f21;
color:white;
padding:10px;
}

td{
padding:10px;
border-bottom:1px solid #ddd;
}

button{
background:#f36f21;
color:white;
border:none;
padding:12px 20px;
margin-top:20px;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#d95e1c;
}

</style>

</head>

<body>

<header>
<h1>Sistema de Matrícula</h1>
</header>

<div class="container">

<h2>Selecciona tus cursos</h2>

<table>

<tr>
<th>Curso</th>
<th>Seleccionar</th>
</tr>

<tr>
<td>COSTOS Y PRESUPUESTOS</td>
<td><input type="checkbox"></td>
</tr>

<tr>
<td>MICROECONOMÍA / MICROECONOMICS</td>
<td><input type="checkbox"></td>
</tr>

<tr>
<td>INTRODUCCIÓN AL MARKETING / INTRODUCTION TO MARKETING</td>
<td><input type="checkbox"></td>
</tr>

<tr>
<td>ESTADÍSTICA PARA LA GESTIÓN EMPRESARIAL II</td>
<td><input type="checkbox"></td>
</tr>

</table>

<button>Confirmar Matrícula</button>

</div>

</body>

</html>
